@model PresentationLayer.Models.ManagePackagesViewModel
@{
    ViewData["Title"] = "Quản lý Gói & Giao dịch Token";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-white border-opacity-10 pb-3">
        <div>
            <h2 class="text-white fw-bold"><i class="bi bi-wallet2 text-warning me-2"></i> Quản lý Gói & Giao dịch Token</h2>
            <p class="text-muted-custom mb-0">Cấu hình các gói token và theo dõi lịch sử thanh toán người dùng.</p>
        </div>
        <button type="button" class="btn btn-primary" onclick="openPackageModal(0, '', 0, 0, 'Month', 1)">
            <i class="bi bi-plus-circle me-1"></i> Thêm gói mới
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success card-glass border-success border-opacity-20 text-white mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger card-glass border-danger border-opacity-20 text-white mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        </div>
    }

    <!-- Tabs chuyển đổi -->
    <ul class="nav nav-tabs border-bottom border-white border-opacity-10 mb-4" id="adminSubTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link nav-link-tab active text-white fw-bold py-3" id="packages-tab" data-bs-toggle="tab" data-bs-target="#packages" type="button" role="tab" aria-controls="packages" aria-selected="true">
                <i class="bi bi-box-seam me-2"></i> Danh sách Gói Token
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link nav-link-tab text-white fw-bold py-3" id="transactions-tab" data-bs-toggle="tab" data-bs-target="#transactions" type="button" role="tab" aria-controls="transactions" aria-selected="false">
                <i class="bi bi-clock-history me-2"></i> Lịch sử Giao dịch mua gói
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link nav-link-tab text-white fw-bold py-3" id="stats-tab" data-bs-toggle="tab" data-bs-target="#statsTabContent" type="button" role="tab" aria-controls="statsTabContent" aria-selected="false">
                <i class="bi bi-bar-chart-line-fill me-2"></i> Thống kê Doanh số
            </button>
        </li>
    </ul>

    <div class="tab-content" id="adminSubTabsContent">
        <!-- Tab 1: Danh sách các gói -->
        <div class="tab-pane fade show active" id="packages" role="tabpanel" aria-labelledby="packages-tab">
            <div class="card card-glass border-white border-opacity-10 shadow-lg">
                <div class="table-responsive">
                    <table class="table table-hover table-custom mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Tên gói</th>
                                <th>Giá tiền</th>
                                <th>Token cộng thêm</th>
                                <th>Thời hạn sử dụng</th>
                                <th class="text-end">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Packages.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted-custom">Không có gói nào tồn tại.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var p in Model.Packages)
                                {
                                    <tr>
                                        <td>
                                            <span class="text-white fw-bold">@p.PackageName</span>
                                        </td>
                                        <td>
                                            <span class="text-warning fw-bold">@p.Price.ToString("N0") VND</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary fs-6">+@p.ExtraTokenAmount.ToString("N0") Tokens</span>
                                        </td>
                                        <td class="text-white">
                                            @p.DurationValue @(p.DurationUnit.Equals("Week", StringComparison.OrdinalIgnoreCase) ? "Tuần" : "Tháng")
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-light" onclick="openPackageModal(@p.PackageId, '@p.PackageName', @p.Price, @p.ExtraTokenAmount, '@p.DurationUnit', @p.DurationValue)">
                                                    <i class="bi bi-pencil-square"></i> Sửa
                                                </button>
                                                <form asp-controller="Subscription" asp-action="DeletePackage" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa gói này? Người dùng sẽ không thể chọn mua gói này nữa.');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@p.PackageId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i> Xóa
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab 2: Lịch sử giao dịch -->
        <div class="tab-pane fade" id="transactions" role="tabpanel" aria-labelledby="transactions-tab">
            <div class="card card-glass border-white border-opacity-10 shadow-lg">
                <div class="table-responsive">
                    <table class="table table-hover table-custom mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Khách hàng</th>
                                <th>Gói đã mua</th>
                                <th>Số tiền</th>
                                <th>Trạng thái</th>
                                <th>Thời gian giao dịch (UTC)</th>
                                <th>Mã giao dịch (ID)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Transactions.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted-custom">Không tìm thấy giao dịch nào.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var t in Model.Transactions)
                                {
                                    var statusBadge = t.TransactionStatus switch
                                    {
                                        "Success" => "bg-success",
                                        "Failed" => "bg-danger",
                                        _ => "bg-warning text-dark"
                                    };

                                    <tr>
                                        <td>
                                            <div class="text-white fw-bold">@t.FullName</div>
                                        </td>
                                        <td>
                                            <span class="text-info fw-bold">@t.PackageName</span>
                                        </td>
                                        <td>
                                            <span class="text-white">@t.Amount.ToString("N0") VND</span>
                                        </td>
                                        <td>
                                            <span class="badge @statusBadge">@t.TransactionStatus</span>
                                        </td>
                                        <td class="text-white-50 small">
                                            @t.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                        </td>
                                        <td class="text-white-50 small font-monospace">
                                            @t.TransactionId
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab 3: Thống kê Doanh số -->
        <div class="tab-pane fade" id="statsTabContent" role="tabpanel" aria-labelledby="stats-tab">
            <!-- KPI Cards -->
            <div class="row g-4 mb-4">
                <!-- Thẻ 1: Tổng Doanh thu -->
                <div class="col-md-6 col-lg-3">
                    <div class="card card-glass p-4 border-white border-opacity-10 shadow-lg">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-muted-custom small uppercase">Doanh thu tổng</span>
                            <div class="avatar-glow bg-success bg-opacity-25 text-success" style="width: 35px; height: 35px;">
                                <i class="bi bi-currency-dollar"></i>
                            </div>
                        </div>
                        <h3 class="text-white fw-bold mb-0">@Model.Stats.TotalRevenue.ToString("N0") <span class="small text-muted-custom" style="font-size: 0.8rem;">VND</span></h3>
                        <div class="text-success small mt-1"><i class="bi bi-arrow-up-circle"></i> Từ giao dịch thành công</div>
                    </div>
                </div>

                <!-- Thẻ 2: Tỉ lệ Thành công -->
                @{
                    int totalCount = Model.Stats.SuccessTransactionsCount + Model.Stats.FailedTransactionsCount + Model.Stats.PendingTransactionsCount;
                    double successRate = totalCount > 0 ? (double)Model.Stats.SuccessTransactionsCount / totalCount * 100.0 : 0.0;
                }
                <div class="col-md-6 col-lg-3">
                    <div class="card card-glass p-4 border-white border-opacity-10 shadow-lg">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-muted-custom small uppercase">Tỷ lệ thanh toán thành công</span>
                            <div class="avatar-glow bg-primary bg-opacity-25 text-primary" style="width: 35px; height: 35px;">
                                <i class="bi bi-patch-check"></i>
                            </div>
                        </div>
                        <h3 class="text-white fw-bold mb-0">@successRate.ToString("F1")%</h3>
                        <div class="text-muted-custom small mt-1">Tổng cộng @totalCount giao dịch</div>
                    </div>
                </div>

                <!-- Thẻ 3: Giao dịch thành công -->
                <div class="col-md-6 col-lg-3">
                    <div class="card card-glass p-4 border-white border-opacity-10 shadow-lg">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-muted-custom small uppercase">Giao dịch thành công</span>
                            <div class="avatar-glow bg-info bg-opacity-25 text-info" style="width: 35px; height: 35px;">
                                <i class="bi bi-check-circle"></i>
                            </div>
                        </div>
                        <h3 class="text-white fw-bold mb-0">@Model.Stats.SuccessTransactionsCount <span class="small text-muted-custom" style="font-size: 0.8rem;">lượt</span></h3>
                        <div class="text-info small mt-1">Đã cộng token tài khoản</div>
                    </div>
                </div>

                <!-- Thẻ 4: Giao dịch lỗi/chờ xử lý -->
                <div class="col-md-6 col-lg-3">
                    <div class="card card-glass p-4 border-white border-opacity-10 shadow-lg">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-muted-custom small uppercase">Giao dịch thất bại / Chờ xử lý</span>
                            <div class="avatar-glow bg-warning bg-opacity-25 text-warning" style="width: 35px; height: 35px;">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                        </div>
                        <h3 class="text-white fw-bold mb-0">
                            @Model.Stats.FailedTransactionsCount 
                            <span class="fs-6 text-muted-custom">lỗi</span> / 
                            @Model.Stats.PendingTransactionsCount 
                            <span class="fs-6 text-muted-custom">chờ</span>
                        </h3>
                        <div class="text-warning small mt-1">Thanh toán hủy hoặc đang kết nối</div>
                    </div>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="row g-4 mb-4">
                <!-- Biểu đồ doanh thu -->
                <div class="col-lg-8">
                    <div class="card card-glass p-4 border-white border-opacity-10 shadow-lg">
                        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                            <h5 class="text-white fw-bold mb-0" id="revenueChartTitle">
                                <i class="bi bi-activity text-primary me-2"></i> Doanh thu trong 30 ngày qua
                            </h5>
                            <div style="width: auto; min-width: 140px;">
                                <select class="form-select form-select-sm bg-dark border-white border-opacity-20 text-white" id="revenuePeriodSelect" onchange="changeRevenuePeriod(this.value)">
                                    <option value="day" selected>Theo ngày</option>
                                    <option value="month">Theo tháng</option>
                                    <option value="quarter">Theo quý</option>
                                    <option value="year">Theo năm</option>
                                </select>
                            </div>
                        </div>
                        <div style="height: 300px; position: relative;">
                            <canvas id="revenueTimeChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Tỉ lệ bán theo từng Gói -->
                <div class="col-lg-4">
                    <div class="card card-glass p-4 border-white border-opacity-10 shadow-lg">
                        <h5 class="text-white fw-bold mb-3"><i class="bi bi-pie-chart text-warning me-2"></i> Phân phối doanh thu gói</h5>
                        <div style="height: 300px; position: relative;">
                            <canvas id="revenuePackageChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bảng xếp hạng bán các gói -->
            <div class="card card-glass border-white border-opacity-10 shadow-lg mb-4">
                <div class="card-header border-bottom border-white border-opacity-10 bg-white bg-opacity-5 py-3">
                    <h5 class="text-white fw-bold mb-0"><i class="bi bi-list-ol text-success me-2"></i> Hiệu suất bán hàng theo từng gói</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-custom mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Tên gói</th>
                                <th>Số lượng đã bán</th>
                                <th>Tổng doanh thu mang lại</th>
                                <th>Tỉ trọng doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Stats.RevenueByPackage.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted-custom">Chưa có giao dịch thành công nào.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model.Stats.RevenueByPackage.OrderByDescending(x => x.Value))
                                {
                                    int sales = Model.Stats.SalesCountByPackage.ContainsKey(item.Key) ? Model.Stats.SalesCountByPackage[item.Key] : 0;
                                    double pct = (double)item.Value / (double)(Model.Stats.TotalRevenue > 0 ? Model.Stats.TotalRevenue : 1) * 100.0;
                                    <tr>
                                        <td>
                                            <span class="text-white fw-bold">@item.Key</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary fs-6">@sales lượt</span>
                                        </td>
                                        <td>
                                            <span class="text-warning fw-bold">@item.Value.ToString("N0") VND</span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1 bg-dark bg-opacity-50" style="height: 6px; width: 100px;">
                                                    <div class="progress-bar bg-success" style="width: @pct%;"></div>
                                                </div>
                                                <span class="text-white small">@pct.ToString("F1")%</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Scripts vẽ biểu đồ (Chart.js) -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // --- 1. Biểu đồ Doanh thu theo Thời gian ---
        const timeCtx = document.getElementById('revenueTimeChart').getContext('2d');
        
        // Dữ liệu từ Model C# đưa vào JS
        const dayLabels = [];
        const dayData = [];
        @foreach (var entry in Model.Stats.RevenueOverTime)
        {
            <text>
                dayLabels.push('@Html.Raw(entry.Key)');
                dayData.push(@entry.Value);
            </text>
        }

        const monthLabels = [];
        const monthData = [];
        @foreach (var entry in Model.Stats.RevenueByMonth)
        {
            <text>
                monthLabels.push('@Html.Raw(entry.Key)');
                monthData.push(@entry.Value);
            </text>
        }

        const quarterLabels = [];
        const quarterData = [];
        @foreach (var entry in Model.Stats.RevenueByQuarter)
        {
            <text>
                quarterLabels.push('@Html.Raw(entry.Key)');
                quarterData.push(@entry.Value);
            </text>
        }

        const yearLabels = [];
        const yearData = [];
        @foreach (var entry in Model.Stats.RevenueByYear)
        {
            <text>
                yearLabels.push('@Html.Raw(entry.Key)');
                yearData.push(@entry.Value);
            </text>
        }

        window.revenueChart = new Chart(timeCtx, {
            type: 'line',
            data: {
                labels: dayLabels.length > 0 ? dayLabels : ["Chưa có dữ liệu"],
                datasets: [{
                    label: 'Doanh thu (VND)',
                    data: dayData.length > 0 ? dayData : [0],
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.3,
                    pointBackgroundColor: '#3b82f6',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        grid: {
                            color: 'rgba(255, 255, 255, 0.05)'
                        },
                        ticks: {
                            color: 'rgba(255, 255, 255, 0.6)',
                            callback: function(value) {
                                return value.toLocaleString() + ' đ';
                            }
                        }
                    },
                    x: {
                        grid: {
                            color: 'rgba(255, 255, 255, 0.05)'
                        },
                        ticks: {
                            color: 'rgba(255, 255, 255, 0.6)'
                        }
                    }
                }
            }
        });

        window.changeRevenuePeriod = function (period) {
            // Đồng bộ giá trị dropdown
            const selectEl = document.getElementById('revenuePeriodSelect');
            if (selectEl && selectEl.value !== period) {
                selectEl.value = period;
            }
            
            let labels = [];
            let data = [];
            let titleText = "";

            if (period === 'day') {
                labels = dayLabels;
                data = dayData;
                titleText = '<i class="bi bi-activity text-primary me-2"></i> Doanh thu trong 30 ngày qua';
            } else if (period === 'month') {
                labels = monthLabels;
                data = monthData;
                titleText = '<i class="bi bi-calendar-range text-primary me-2"></i> Doanh thu theo Tháng (12 tháng qua)';
            } else if (period === 'quarter') {
                labels = quarterLabels;
                data = quarterData;
                titleText = '<i class="bi bi-grid-3x3-gap text-primary me-2"></i> Doanh thu theo Quý (8 quý qua)';
            } else if (period === 'year') {
                labels = yearLabels;
                data = yearData;
                titleText = '<i class="bi bi-calendar3 text-primary me-2"></i> Doanh thu theo Năm';
            }

            document.getElementById('revenueChartTitle').innerHTML = titleText;

            if (window.revenueChart) {
                window.revenueChart.data.labels = labels.length > 0 ? labels : ["Chưa có dữ liệu"];
                window.revenueChart.data.datasets[0].data = data.length > 0 ? data : [0];
                window.revenueChart.update();
            }
        };

        // --- 2. Biểu đồ Tỷ trọng Doanh thu theo Gói ---
        const packageCtx = document.getElementById('revenuePackageChart').getContext('2d');
        
        const packageLabels = [];
        const packageData = [];
        
        @foreach (var entry in Model.Stats.RevenueByPackage)
        {
            <text>
                packageLabels.push('@Html.Raw(entry.Key)');
                packageData.push(@entry.Value);
            </text>
        }

        new Chart(packageCtx, {
            type: 'doughnut',
            data: {
                labels: packageLabels.length > 0 ? packageLabels : ["Chưa bán được gói nào"],
                datasets: [{
                    data: packageData.length > 0 ? packageData : [1],
                    backgroundColor: [
                        '#3b82f6',
                        '#8b5cf6',
                        '#fbbf24',
                        '#ec4899',
                        '#10b981'
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: 'rgba(255, 255, 255, 0.8)',
                            padding: 15,
                            font: {
                                size: 11
                            }
                        }
                    }
                }
            }
        });
    });
</script>

<!-- Modal Form Thêm/Sửa Gói -->
<div class="modal fade" id="packageModal" tabindex="-1" aria-labelledby="packageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content card-glass border-white border-opacity-15 shadow-2xl text-white">
            <div class="modal-header border-bottom border-white border-opacity-10">
                <h5 class="modal-title" id="packageModalLabel">Cấu hình gói dịch vụ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Subscription" asp-action="CreateOrUpdatePackage" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="packageId" name="PackageId" value="0" />
                
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="packageName" class="form-label">Tên gói dịch vụ</label>
                        <input type="text" class="form-control bg-dark border-white border-opacity-20 text-white" id="packageName" name="PackageName" required placeholder="Ví dụ: Gói Tháng Học Tập" />
                    </div>

                    <div class="mb-3">
                        <label for="price" class="form-label">Giá tiền (VND)</label>
                        <input type="number" class="form-control bg-dark border-white border-opacity-20 text-white" id="price" name="Price" required min="1000" placeholder="50000" />
                    </div>

                    <div class="mb-3">
                        <label for="extraTokenAmount" class="form-label">Số lượng Token cấp thêm</label>
                        <input type="number" class="form-control bg-dark border-white border-opacity-20 text-white" id="extraTokenAmount" name="ExtraTokenAmount" required min="1000" placeholder="200000" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="durationUnit" class="form-label">Đơn vị hạn sử dụng</label>
                            <select class="form-select bg-dark border-white border-opacity-20 text-white" id="durationUnit" name="DurationUnit">
                                <option value="Week">Tuần</option>
                                <option value="Month">Tháng</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="durationValue" class="form-label">Độ dài</label>
                            <input type="number" class="form-control bg-dark border-white border-opacity-20 text-white" id="durationValue" name="DurationValue" required min="1" value="1" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-top border-white border-opacity-10">
                    <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu cấu hình</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openPackageModal(id, name, price, tokens, unit, val) {
        document.getElementById('packageId').value = id;
        document.getElementById('packageName').value = name;
        document.getElementById('price').value = price;
        document.getElementById('extraTokenAmount').value = tokens;
        document.getElementById('durationUnit').value = unit;
        document.getElementById('durationValue').value = val;

        document.getElementById('packageModalLabel').innerText = id > 0 ? "Chỉnh sửa gói dịch vụ" : "Thêm gói dịch vụ mới";
        
        var modal = new bootstrap.Modal(document.getElementById('packageModal'));
        modal.show();
    }
</script>

