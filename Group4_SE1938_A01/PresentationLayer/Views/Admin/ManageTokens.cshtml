@model IEnumerable<PresentationLayer.Models.UserTokenUsageViewModel>

@{
    ViewData["Title"] = "Quản lý Token";
    Layout = "_Layout";
}

<div class="container-fluid px-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h2 class="card-title-gradient mb-1">
                <i class="bi bi-coin text-glow"></i> Quản lý Hạn mức Token
            </h2>
            <p class="text-muted-custom mb-0">
                Theo dõi việc tiêu thụ token và thiết lập hạn mức hàng tuần cho sinh viên và giáo viên.
            </p>
        </div>

        <div>
            <button class="btn btn-glow-primary d-flex align-items-center gap-2"
                    data-bs-toggle="modal" data-bs-target="#updateAllLimitsModal">
                <i class="bi bi-gear-fill"></i> Thiết lập hạn mức chung
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["Success"])',
                    background: 'rgba(13, 17, 28, 0.95)',
                    color: '#fff',
                    confirmButtonColor: '#6366f1'
                });
            });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Thất bại!',
                    text: '@Html.Raw(TempData["Error"])',
                    background: 'rgba(13, 17, 28, 0.95)',
                    color: '#fff',
                    confirmButtonColor: '#ef4444'
                });
            });
        </script>
    }

    <!-- Search & Filter bar -->
    <div class="card-glass py-3 mb-4">
        <form asp-action="ManageTokens" method="get" id="searchForm">
            <div class="row align-items-center g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-blur border-end-0 border-white border-opacity-10 text-muted-custom" style="border-radius: 8px 0 0 8px;">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                               class="form-control form-glass border-start-0" style="border-radius: 0 8px 8px 0;"
                               placeholder="Tìm kiếm theo Tên, Email, Username..." id="searchInput"
                               autocomplete="off" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="roleFilter" class="form-select form-glass" onchange="document.getElementById('searchForm').submit();" style="border-radius: 8px;">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.RoleFilter) ? "selected" : null)">Tất cả vai trò</option>
                        <option value="Student" selected="@(ViewBag.RoleFilter == "Student" ? "selected" : null)">Sinh viên</option>
                        <option value="Teacher" selected="@(ViewBag.RoleFilter == "Teacher" ? "selected" : null)">Giáo viên</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-glow-primary w-100">
                        <i class="bi bi-funnel"></i> Lọc kết quả
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Token Table -->
    <div class="card-glass p-0 overflow-hidden shadow-lg">
        <div class="table-responsive">
            <table class="table table-glass mb-0">
                <thead>
                    <tr>
                        <th style="width:80px;">ID</th>
                        <th>Họ và tên / Email</th>
                        <th>Vai trò</th>
                        <th>Hạn mức / Tuần</th>
                        <th style="width: 200px;">Đã sử dụng</th>
                        <th>Còn lại (Free)</th>
                        <th>Token mua thêm</th>
                        <th>Hạn dùng gói</th>
                        <th>Trạng thái</th>
                        <th class="text-end" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center py-5">
                                <i class="bi bi-lightning-charge fs-1 text-muted-custom d-block mb-2"></i>
                                <span class="text-muted-custom">Không tìm thấy người dùng nào trong hệ thống.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            var usagePct = user.UsagePercentage;
                            string progressColorClass = "bg-success";
                            string badgeClass = "bg-success bg-opacity-25 text-success border border-success border-opacity-20";
                            string statusText = "An toàn";

                            if (usagePct >= 100.0)
                            {
                                progressColorClass = "bg-danger";
                                badgeClass = "bg-danger bg-opacity-25 text-danger border border-danger border-opacity-20";
                                statusText = "Hết hạn mức";
                            }
                            else if (usagePct >= 80.0)
                            {
                                progressColorClass = "bg-warning";
                                badgeClass = "bg-warning bg-opacity-25 text-warning border border-warning border-opacity-20";
                                statusText = "Cảnh báo";
                            }

                            // Nếu có token mua và chưa hết hạn, trạng thái có thêm nhãn VIP
                            bool hasActivePaidTokens = user.PurchasedTokenBalance > 0 && (user.PurchasedTokenExpiry == null || user.PurchasedTokenExpiry > DateTime.UtcNow);

                            <tr id="user-row-@user.UserId">
                                <td><strong class="text-muted-custom">#@user.UserId</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-glow" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                            @(string.IsNullOrEmpty(user.FullName) ? "?" : user.FullName[0].ToString().ToUpper())
                                        </div>
                                        <div>
                                            <span class="fw-semibold text-white d-block user-fullname-span">
                                                @user.FullName
                                                <span class="user-pro-badge badge bg-warning text-dark small ms-1 @(hasActivePaidTokens ? "" : "d-none")" style="font-size: 0.65rem; padding: 2px 4px;">PRO</span>
                                            </span>
                                            <small class="text-muted-custom" style="font-size: 0.75rem;">@user.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (user.Role == "Teacher")
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-20 px-2 py-1">Giáo viên</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-muted-custom border border-secondary border-opacity-20 px-2 py-1">Sinh viên</span>
                                    }
                                </td>
                                <td class="text-white fw-bold user-limit-val">@user.WeeklyTokenLimit.ToString("N0")</td>
                                <td class="user-used-cell" data-used="@user.WeeklyTokenUsed" data-limit="@user.WeeklyTokenLimit">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="text-glow text-white small user-used-val">@user.WeeklyTokenUsed.ToString("N0")</span>
                                        <span class="text-muted-custom small user-pct-val">@usagePct%</span>
                                    </div>
                                    <div class="progress bg-dark bg-opacity-50" style="height: 6px; border-radius: 3px;">
                                        <div class="progress-bar user-progress-bar @progressColorClass" role="progressbar" 
                                             style="width: @usagePct%;" 
                                             aria-valuenow="@user.WeeklyTokenUsed" 
                                             aria-valuemin="0" 
                                             aria-valuemax="@user.WeeklyTokenLimit"></div>
                                    </div>
                                </td>
                                <td class="text-white user-remaining-val">@user.RemainingTokens.ToString("N0")</td>
                                <td class="user-purchased-val">
                                    @if (user.PurchasedTokenBalance > 0)
                                    {
                                        <span class="text-warning fw-bold font-monospace">+@user.PurchasedTokenBalance.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted-custom">-</span>
                                    }
                                </td>
                                <td>
                                    @if (user.PurchasedTokenExpiry != null)
                                    {
                                        var isExpired = user.PurchasedTokenExpiry < DateTime.UtcNow;
                                        <span class="@(isExpired ? "text-danger text-decoration-line-through" : "text-success") small">
                                            @user.PurchasedTokenExpiry.Value.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted-custom small">Không sử dụng</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge user-status-badge @badgeClass px-2 py-1">@statusText</span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-glass btn-edit-limit" 
                                            data-id="@user.UserId" 
                                            data-name="@user.FullName"
                                            data-limit="@user.WeeklyTokenLimit"
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editLimitModal">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Edit Individual Limit -->
<div class="modal fade" id="editLimitModal" tabindex="-1" aria-labelledby="editLimitModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title card-title-gradient mb-0" id="editLimitModalLabel">
                    <i class="bi bi-pencil-square text-glow"></i> Chỉnh sửa hạn mức người dùng
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateTokenLimit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="editUserId" />
                <div class="modal-body modal-body-glass">
                    <div class="mb-3">
                        <label class="form-label text-muted-custom">Họ và tên người dùng</label>
                        <input type="text" class="form-control form-glass text-white" id="editFullName" readonly style="opacity: 0.7;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white fw-semibold">Hạn mức Token hàng tuần</label>
                        <input type="number" name="newLimit" id="editLimitValue" class="form-control form-glass text-white" required min="0" step="1000" />
                        <div class="form-text text-muted-custom">
                            Hạn mức token được áp dụng mỗi tuần và tự động reset vào Thứ Hai.
                        </div>
                    </div>
                </div>
                <div class="modal-footer modal-header-glass border-top border-white border-opacity-10">
                    <button type="button" class="btn btn-outline-glass" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-glow-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Update All Limits -->
<div class="modal fade" id="updateAllLimitsModal" tabindex="-1" aria-labelledby="updateAllLimitsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title card-title-gradient mb-0" id="updateAllLimitsModalLabel">
                    <i class="bi bi-gear-fill text-glow"></i> Thiết lập hạn mức mặc định chung
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateAllTokenLimits" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body modal-body-glass">
                    <div class="alert alert-warning bg-warning bg-opacity-10 border border-warning border-opacity-25 text-warning mb-3">
                        <i class="bi bi-exclamation-triangle-fill"></i> <strong>Lưu ý:</strong> Hành động này sẽ thay đổi hạn mức của <strong>tất cả sinh viên và giáo viên</strong> trong hệ thống thành giá trị mới.
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white fw-semibold">Hạn mức mặc định mới (Tokens/Tuần)</label>
                        <input type="number" name="newLimit" value="250000" class="form-control form-glass text-white" required min="0" step="50000" />
                        <div class="form-text text-muted-custom">
                            Giá trị khuyến nghị: 250,000 đến 500,000 tokens/tuần.
                        </div>
                    </div>
                </div>
                <div class="modal-footer modal-header-glass border-top border-white border-opacity-10">
                    <button type="button" class="btn btn-outline-glass" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-glow-primary">Cập nhật tất cả</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Handle loading data to edit individual limit modal
        const editButtons = document.querySelectorAll('.btn-edit-limit');
        editButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                const name = this.getAttribute('data-name');
                const limit = this.getAttribute('data-limit');
                
                document.getElementById('editUserId').value = id;
                document.getElementById('editFullName').value = name;
                document.getElementById('editLimitValue').value = limit;
            });
        });

        // --- SignalR Realtime Updates ---
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/newsHub")
            .withAutomaticReconnect()
            .build();

        // Helper to format number
        function formatNumber(num) {
            return num.toString().replace(/(\d)(?=(\d{3})+(?!\d))/g, '$1,');
        }

        // Helper to update progress bar and status
        function updateRowStatus($row, limit, used) {
            var pct = 0;
            if (limit > 0) {
                pct = Math.min(100.0, Math.round((used / limit) * 100.0, 1));
            } else {
                pct = 100.0;
            }

            // Update used & pct labels
            $row.find('.user-used-val').text(formatNumber(used));
            $row.find('.user-pct-val').text(pct + '%');

            // Update progress bar width and class
            var $bar = $row.find('.user-progress-bar');
            $bar.css('width', pct + '%');
            $bar.attr('aria-valuenow', used);
            $bar.attr('aria-valuemax', limit);

            // Update remaining
            var remaining = Math.max(0, limit - used);
            $row.find('.user-remaining-val').text(formatNumber(remaining));

            // Update status badge class and text
            var $badge = $row.find('.user-status-badge');
            $badge.removeClass('bg-success bg-warning bg-danger text-success text-warning text-danger border-success border-warning border-danger');
            
            if (pct >= 100.0) {
                $bar.removeClass('bg-success bg-warning').addClass('bg-danger');
                $badge.addClass('bg-danger bg-opacity-25 text-danger border border-danger border-opacity-20').text('Hết hạn mức');
            } else if (pct >= 80.0) {
                $bar.removeClass('bg-success bg-danger').addClass('bg-warning');
                $badge.addClass('bg-warning bg-opacity-25 text-warning border border-warning border-opacity-20').text('Cảnh báo');
            } else {
                $bar.removeClass('bg-warning bg-danger').addClass('bg-success');
                $badge.addClass('bg-success bg-opacity-25 text-success border border-success border-opacity-20').text('An toàn');
            }
        }

        // 1. Lắng nghe cập nhật hạn mức (hoặc token mua thêm)
        connection.on("ReceiveUserTokenLimitUpdated", function (userId, newLimit, purchasedBalance) {
            var $row = $('#user-row-' + userId);
            if ($row.length > 0) {
                var $purchasedVal = $row.find('.user-purchased-val');
                if (purchasedBalance > 0) {
                    $purchasedVal.html('<span class="text-warning fw-bold font-monospace">+' + formatNumber(purchasedBalance) + '</span>');
                    $row.find('.user-pro-badge').removeClass('d-none');
                } else {
                    $purchasedVal.html('<span class="text-muted-custom">-</span>');
                    $row.find('.user-pro-badge').addClass('d-none');
                }

                // Cập nhật lại logic hạn mức nếu cần
                var $cell = $row.find('.user-used-cell');
                var used = parseInt($cell.attr('data-used')) || 0;
                var baseLimit = parseInt($row.find('.user-limit-val').text().replace(/,/g, '')) || 0;
                
                var activeLimit = baseLimit + purchasedBalance;
                $cell.attr('data-limit', activeLimit);
                updateRowStatus($row, activeLimit, used);
            }
        });

        // 2. Lắng nghe cập nhật lượng token đã sử dụng khi user chat
        connection.on("ReceiveUserTokenUsageUpdated", function (userId, totalWeeklyUsed) {
            var $row = $('#user-row-' + userId);
            if ($row.length > 0) {
                var $cell = $row.find('.user-used-cell');
                $cell.attr('data-used', totalWeeklyUsed);
                
                var limit = parseInt($cell.attr('data-limit')) || 0;
                updateRowStatus($row, limit, totalWeeklyUsed);
            }
        });

        connection.start().catch(err => console.error("SignalR Connection Error: ", err));
    });
</script>
