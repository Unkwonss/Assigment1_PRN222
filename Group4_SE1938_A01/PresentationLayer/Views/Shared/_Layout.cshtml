<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAG Chatbot & Research Benchmark</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- Custom Style -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- SweetAlert2 & Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark bg-blur border-bottom border-dark-subtle">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Account" asp-action="Login">
                    <div class="brand-logo-glow">
                        <i class="bi bi-cpu-fill fs-4 text-glow"></i>
                    </div>
                    <span class="brand-text">VietRAG <span class="badge-role">System</span></span>
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1 mt-2 mt-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")" asp-controller="Account" asp-action="Users">
                                        <i class="bi bi-people-fill"></i> Quản lý tài khoản
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "ManageStudents" ? "active" : "")" asp-controller="Admin" asp-action="ManageStudents">
                                        <i class="bi bi-mortarboard-fill"></i> Quản lý sinh viên
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Document" ? "active" : "")" asp-controller="Document" asp-action="Index">
                                        <i class="bi bi-folder-fill"></i> Tài liệu
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chat" ? "active" : "")" asp-controller="Chat" asp-action="Index">
                                        <i class="bi bi-chat-left-text-fill"></i> Chatbot RAG
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Benchmark" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Benchmark" asp-action="Index">
                                        <i class="bi bi-cpu-fill"></i> RAG Benchmarks
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Benchmark" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Benchmark" asp-action="Dashboard">
                                        <i class="bi bi-graph-up-arrow"></i> Thống kê RAG
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Teacher"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Document" ? "active" : "")" asp-controller="Document" asp-action="Index">
                                        <i class="bi bi-folder-fill"></i> Tài liệu & Chapter
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chat" ? "active" : "")" asp-controller="Chat" asp-action="Index">
                                        <i class="bi bi-chat-left-text-fill"></i> Chatbot RAG
                                    </a>
                                </li>
                            }
                            else // Student
                            {
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chat" ? "active" : "")" asp-controller="Chat" asp-action="Index">
                                        <i class="bi bi-chat-left-text-fill"></i> Trò chuyện học tập
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    
                    <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Profile" asp-action="Index" class="user-profile-nav d-none d-sm-flex align-items-center gap-2 text-decoration-none">
                                <div class="avatar-glow">
                                    <span class="avatar-text">@User.Identity.Name?[0].ToString().ToUpper()</span>
                                </div>
                                <div class="profile-details text-start">
                                    <div class="profile-name text-white">@User.Identity.Name</div>
                                    <div class="profile-role text-muted-custom">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                                </div>
                            </a>
                            
                            <a class="btn btn-logout d-flex align-items-center gap-2" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> <span>Đăng xuất</span>
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-login-nav d-flex align-items-center gap-2" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                            <a class="btn btn-register-nav d-flex align-items-center gap-2" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus-fill"></i> Đăng ký
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="main-content-area">
        @RenderBody()
    </main>

    <footer class="footer-blur border-top border-dark-subtle py-4 text-center mt-auto">
        <div class="container text-muted-custom">
            &copy; 2026 - Vietnamese RAG Chatbot & RBL Benchmark System - Group 4 SE1938
        </div>
    </footer>
    
    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
